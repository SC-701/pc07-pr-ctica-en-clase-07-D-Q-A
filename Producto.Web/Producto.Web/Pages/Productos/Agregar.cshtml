@page
@model Producto.Web.Pages.Productos.AgregarModelo
@{
}
<h1>Agregar Producto</h1>
<div class="container">
    <div class="col-xl-8 col-lg-6 col-md-8 col-sm-10 mx-auto">
        <form method="post">
            <div class="form-group">
                <label for="categorias">Categorias</label>
                <Select asp-for="categoriaseleccionada" class="form-select" asp-items="Model.categorias" id="categorias" onchange="fetchSubCategorias()">
                    <option value="">
                        Seleccione una categoria
                    </option>
                </Select>
            </div>
            <div class="form-group">
                <label for="subcategorias">SubCategorias</label>
                <Select asp-for="producto.IdSubCategoria" class="form-select" asp-items="Model.subcategorias" id="subcategorias">
                    <option value="">
                        Seleccione un subcategoria
                    </option>
                </Select>
            </div>
            <div class="form-group">
                <label asp-for="producto.Nombre" class="control-label"></label>
                <input class="form-control" asp-for="producto.Nombre" />
                <span class="text-danger" asp-validation-for="producto.Nombre"></span>
            </div>

            <div class="form-group">
                <label asp-for="producto.Descripcion" class="control-label"></label>
                <input class="form-control" asp-for="producto.Descripcion" />
                <span class="text-danger" asp-validation-for="producto.Descripcion"></span>
            </div>

            <div class="form-group">
                <label asp-for="producto.Precio" class="control-label"></label>
                <input class="form-control" asp-for="producto.Precio" />
                <span class="text-danger" asp-validation-for="producto.Precio"></span>
            </div>

            <div class="form-group">
                <label asp-for="producto.Stock" class="control-label"></label>
                <input class="form-control" asp-for="producto.Stock" />
                <span class="text-danger" asp-validation-for="producto.Stock"></span>
            </div>

            <div class="form-group">
                <label asp-for="producto.CodigoBarras" class="control-label"></label>
                <input class="form-control" asp-for="producto.CodigoBarras" />
                <span class="text-danger" asp-validation-for="producto.CodigoBarras"></span>
            </div>

            <div class=" text-danger" asp-validation-summary="All"></div>
            <div class="form-group">
                <a class=" btn btn-primary " asp-page="./Index">Regresar</a>
                <input class="btn btn-success" type="submit" value="Agregar" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        async function fetchSubCategorias() {
            const categoriaId = document.getElementById("categorias").value;
            if (!categoriaId) { return; }
            try {
                const respuesta = await fetch(`?handler=ObtenerSubCategorias&categoriaId=${categoriaId}`);
                const subcategorias = await respuesta.json();
                const subcategoriasSelect = document.getElementById("subcategorias");
                subcategoriasSelect.innerHTML = '<option value="">Seleccione un subcategoria</option>'
                subcategorias.forEach(
                    subcategoria => {
                        const option = document.createElement("option");
                        option.value = subcategoria.id;
                        option.text = subcategoria.nombre;
                        subcategoriasSelect.appendChild(option);
                    }
                )
            }
            catch(error){
                console.error('Error obteniendo los datos', error);
            }
        }

    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}